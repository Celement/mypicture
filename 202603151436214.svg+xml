          stroke: #000000 !important;
          stroke-width: 3px !important;
          rx: 12px !important;
        }
        
        .task-section:nth-child(2n) {
          fill: #dff4ff !important;
        }
        
        .task-section:nth-child(3n) {
          fill: #fff4e6 !important;
        }
        
        /* XYChart styles - Doodle theme colors */
        .line-plot-0 path {
