          stroke-width: 4px !important;
          stroke-linecap: round;
          stroke-linejoin: round;
        }
        
        .line-plot-2 path {
          stroke: #9333ea !important;
          stroke-width: 4px !important;
          stroke-linecap: round;
          stroke-linejoin: round;
        }
        
        .bar-plot-0 rect {
          fill: #fce7f3 !important;
          stroke: #ec4899 !important;
          stroke-width: 3px !important;
          rx: 8px !important;
        }
        
        .bar-plot-1 rect {
