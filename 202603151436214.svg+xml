          stroke-width: 3px !important;
          rx: 8px !important;
        }
        
        .bar-plot-2 rect {
          fill: #f3e8ff !important;
          stroke: #9333ea !important;
          stroke-width: 3px !important;
          rx: 8px !important;
        }
        
        .ticks path {
          stroke: #000000 !important;
          stroke-width: 2px !important;
        }
        
        .chart-title text {
          fill: #000000 !important;
          font-weight: 700 !important;
          font-size: 20px !important;
          font-family: "Comic Neue", "Comic Sans MS", "Noto Sans SC", cursive, sans-serif;
        }
        
        .left-axis .label text, .bottom-axis .label text {
          fill: #000000 !important;
          font-size: 14px !important;
          font-family: "Comic Neue", "Comic Sans MS", "Noto Sans SC", cursive, sans-serif;
          font-weight: 600;
        }
        
        .left-axis .title text, .bottom-axis .title text {
          fill: #000000 !important;
          font-size: 16px !important;
          font-family: "Comic Neue", "Comic Sans MS", "Noto Sans SC", cursive, sans-serif;
          font-weight: 700;
        }
        
        .legend text {
          fill: #000000 !important;
          font-size: 14px !important;
          font-family: "Comic Neue", "Comic Sans MS", "Noto Sans SC", cursive, sans-serif;
          font-weight: 600;
        }
        
        .legend rect {
          stroke: #000000 !important;
          stroke-width: 2px !important;
          rx: 6px !important;
        }
        
        /* Git Graph */
        .commit-id, .commit-msg, .branch-label {
          fill: #000000 !important;
          font-family: "Comic Neue", "Comic Sans MS", "Noto Sans SC", cursive, sans-serif;
          font-weight: 600;
        }
        
        .commit {
          stroke: #000000 !important;
          stroke-width: 3px !important;
        }
        
        .commit0 {
          fill: #ffdff6 !important;
        }
        
        .commit1 {
          fill: #dff4ff !important;
        }
        
        .commit2 {
          fill: #f0e7ff !important;
        }
        
        .commit3 {
          fill: #fff4e6 !important;
        }
        
        .commit-highlight-outer {
          fill: #fbbf24;
          opacity: 0.3;
        }
        
        .commit-highlight-inner {
          fill: #fbbf24;
          opacity: 0.5;
          stroke: #f59e0b;
        }
        
        .branch path {
          stroke-width: 3px !important;
          stroke-linecap: round;
          stroke-linejoin: round;
        }
        
        .branch.branch0 {
          stroke: #ec4899 !important;
        }
        
        .branch.branch1 {
          stroke: #3b82f6 !important;
        }
        
        .branch.branch2 {
          stroke: #9333ea !important;
        }
        
        .branch.branch3 {
          stroke: #f59e0b !important;
        }
        
        /* Timeline */
        .timeline-event {
          fill: #ffdff6 !important;
          stroke: #000000 !important;
          stroke-width: 3px !important;
          rx: 15px !important;
          filter: drop-shadow(3px 3px 0px rgba(0,0,0,0.15));
        }
        
        .timeline-event:nth-child(2n) {
